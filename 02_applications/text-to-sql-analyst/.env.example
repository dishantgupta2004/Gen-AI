# ============================================================
# Text-to-SQL Enterprise Analyst — Environment Configuration
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ---- App ----
ENVIRONMENT=development
DEBUG=false
CORS_ORIGINS=["http://localhost:8501","https://your-frontend.streamlit.app"]

# ---- PostgreSQL ----
# IMPORTANT: use a dedicated READ-ONLY role for the agent.
#   CREATE ROLE analyst_ro LOGIN PASSWORD '...';
#   GRANT CONNECT ON DATABASE mydb TO analyst_ro;
#   GRANT USAGE ON SCHEMA public TO analyst_ro;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO analyst_ro;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO analyst_ro;
DATABASE_URL=postgresql+asyncpg://analyst_ro:password@host:5432/yourdb
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
STATEMENT_TIMEOUT_MS=15000

# ---- LLM (Groq, Llama 3) ----
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ---- Auth ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-at-least-32-random-bytes-please
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Demo login (replace with Supabase Auth in production)
DEMO_USER=analyst
DEMO_PASSWORD=analyst

# ---- Limits & safety ----
MAX_ROWS_RETURNED=10000
MAX_QUERY_CHARS=4000
RATE_LIMIT_PER_MINUTE=30

# ---- Optional cache ----
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=300

# ---- Frontend ----
BACKEND_URL=http://localhost:8000
